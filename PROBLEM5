import java.util.*;

class Transaction {
    String accountId;
    double amount;
    String timestamp;

    public Transaction(String accountId, double amount, String timestamp) {
        this.accountId = accountId;
        this.amount = amount;
        this.timestamp = timestamp;
    }

    @Override
    public String toString() {
        return accountId + ":" + amount + "@" + timestamp;
    }
}

public class AccountIdLookup {

    // Linear Search: first occurrence
    public static int linearFirst(Transaction[] logs, String target) {
        int comparisons = 0;
        for (int i = 0; i < logs.length; i++) {
            comparisons++;
            if (logs[i].accountId.equals(target)) {
                System.out.println("Linear first " + target + ": index " + i + " (" + comparisons + " comparisons)");
                return i;
            }
        }
        System.out.println("Linear first " + target + ": not found (" + comparisons + " comparisons)");
        return -1;
    }

    // Linear Search: last occurrence
    public static int linearLast(Transaction[] logs, String target) {
        int comparisons = 0;
        int lastIndex = -1;
        for (int i = 0; i < logs.length; i++) {
            comparisons++;
            if (logs[i].accountId.equals(target)) {
                lastIndex = i;
            }
        }
        if (lastIndex != -1) {
            System.out.println("Linear last " + target + ": index " + lastIndex + " (" + comparisons + " comparisons)");
        } else {
            System.out.println("Linear last " + target + ": not found (" + comparisons + " comparisons)");
        }
        return lastIndex;
    }

    // Binary Search: first occurrence + count occurrences
    public static void binarySearch(Transaction[] logs, String target) {
        Arrays.sort(logs, Comparator.comparing(t -> t.accountId)); // sort by accountId
        int low = 0, high = logs.length - 1;
        int comparisons = 0;
        int first = -1;

        // Find first occurrence
        while (low <= high) {
            int mid = low + (high - low) / 2;
            comparisons++;
            int cmp = logs[mid].accountId.compareTo(target);
            if (cmp < 0) low = mid + 1;
            else {
                if (cmp == 0) first = mid;
                high = mid - 1;
            }
        }

        if (first == -1) {
            System.out.println("Binary " + target + ": not found (" + comparisons + " comparisons)");
            return;
        }

        // Count occurrences
        int count = 0;
        for (int i = first; i < logs.length && logs[i].accountId.equals(target); i++) count++;

        System.out.println("Binary " + target + ": index " + first + " (" + comparisons + " comparisons), count=" + count);
    }

    public static void main(String[] args) {
        Transaction[] logs = {
            new Transaction("accB", 100, "10:00"),
            new Transaction("accA", 200, "09:30"),
            new Transaction("accB", 150, "10:15"),
            new Transaction("accC", 300, "11:00")
        };

        linearFirst(logs, "accB");
        linearLast(logs, "accB");
        binarySearch(logs, "accB");
    }
}
